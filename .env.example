# Update these with your Supabase details from your project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Wompi Payment Gateway (Colombia)
# Get these from Wompi Dashboard > Programadores
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_INTEGRITY_SECRET=test_integrity_...
WOMPI_EVENTS_SECRET=test_events_...
# Note: Private key usually not needed for Widget but good to have if using API
WOMPI_PRIVATE_KEY=prv_test_...

# Site URL for redirection and webhooks
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
