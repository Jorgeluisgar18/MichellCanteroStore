# Update these with your Supabase details from your project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe / Wompi / Payment Gateway Public Keys
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_...

# Note: Secret keys (Service Role, Wompi Private Key/integrity) should NOT be exposed to the client
# and should be kept in .env.local only if needed for API routes
